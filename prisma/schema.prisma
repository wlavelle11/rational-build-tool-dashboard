generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Deal {
  id                      String   @id @default(cuid())
  name                    String
  neighborhood            String
  address                 String?
  units                   Int
  purchasePrice           Float
  monthlyGrossRent        Float
  vacancyRate             Float
  operatingExpenseRatio   Float
  annualRentGrowth        Float
  annualExpenseGrowth     Float    @default(0.03)
  holdPeriodYears         Int      @default(10)
  exitCapRate             Float
  acquisitionClosingCosts Float
  renovationCapex         Float    @default(0)
  equityInvested          Float
  preferredReturnRate     Float    @default(0.06)
  sponsorPromoteRate      Float    @default(0.30)
  cachedIRR               Float?
  cachedEquityMultiple    Float?
  cachedCapRate           Float?
  cachedScore             Float?
  cachedRecommendation    String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([updatedAt])
}

model ADUProject {
  id                     String   @id @default(cuid())
  name                   String
  neighborhood           String
  address                String?
  apn                    String?
  purchasePrice          Float

  // Feasibility inputs
  lotSizeSqft            Float    @default(0)
  existingCoverageSqft   Float    @default(0)
  zoningCode             String   @default("")
  setbackFront           Boolean  @default(false)
  setbackRear            Boolean  @default(false)
  setbackSide            Boolean  @default(false)
  utilityWater           String   @default("adequate")
  utilitySewer           String   @default("adequate")
  hasHOA                 Boolean  @default(false)
  permitTimelineMonths   Int      @default(6)
  permitCostEstimate     Float    @default(15000)

  // Financial analysis inputs
  aduCount               Int      @default(4)
  constructionCost       Float    @default(600000)
  marketRateUnits        Int      @default(2)
  middleIncomeUnits      Int      @default(2)
  marketRateRent         Float    @default(2400)
  middleIncomeRent       Float    @default(1900)
  vacancyRate            Float    @default(0.05)
  opExpRatio             Float    @default(0.30)
  annualRentGrowth       Float    @default(0.055)
  holdPeriodYears        Int      @default(10)
  exitCapRate            Float    @default(0.05)
  equityInvested         Float    @default(1800000)
  preferredReturnRate    Float    @default(0.06)
  sponsorSplit           Float    @default(0.70)

  // Cached metrics
  cachedFeasibilityScore Float?
  cachedFeasibilityFlag  String?
  cachedIRR              Float?
  cachedEquityMultiple   Float?
  cachedRecommendation   String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([updatedAt])
}

model Lead {
  id           String   @id @default(cuid())
  address      String   @unique
  zipCode      String?
  leadType     String?
  tab          String   // NOD | Auction | Listed | Archived
  distressType String?
  filingDate   String?
  estValue     Float?
  loanAmount   Float?
  equity       Float?
  equityPct    Float?
  yearBuilt    String?
  beds         String?
  baths        String?
  sqft         String?
  score        Int      @default(0)
  status       String?
  sources      String?
  priority     Boolean  @default(false)
  saved        Boolean  @default(false)
  photoUrl     String?
  notes        String?
  firstSeen    String?
  lastSeen     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tab, score])
  @@index([saved])
}

model ResidentialProject {
  id                    String   @id @default(cuid())
  name                  String
  neighborhood          String
  address               String?

  // Shared property inputs
  purchasePrice         Float
  renovationBudget      Float
  arv                   Float
  buyClosingCosts       Float

  // Flip inputs
  flipInvestorCapital   Float
  flipHoldMonths        Int
  flipMonthlyCarrying   Float
  flipSellClosingPct    Float    @default(0.07)
  flipFinancingType     String   @default("cash")
  flipHardMoneyLtvPct   Float?
  flipHardMoneyRate     Float?
  flipHardMoneyPoints   Float?

  // BRRR inputs
  brrrInvestorCapital   Float
  brrrHoldYears         Int      @default(10)
  brrrMonthlyRent       Float
  brrrOpExpRatio        Float    @default(0.35)
  brrrReservePct        Float    @default(0.05)
  brrrRefinanceLtv      Float    @default(0.75)
  brrrRefinanceRate     Float    @default(0.07)
  brrrRefinanceTerm     Int      @default(30)
  brrrTargetYield       Float    @default(0.08)
  brrrEquitySplit       Float    @default(0.50)
  brrrFinancingType     String   @default("cash")
  brrrHardMoneyLtvPct   Float?
  brrrHardMoneyRate     Float?
  brrrHardMoneyPoints   Float?
  brrrRenovationMonths  Int?

  // Cached metrics
  cachedFlipScore       Float?
  cachedFlipRec         String?
  cachedFlipROI         Float?
  cachedBrrrScore       Float?
  cachedBrrrRec         String?
  cachedBrrrYield       Float?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([updatedAt])
}

